# Ceres credentials & feed settings.
# Copy to .env (which is gitignored — NEVER commit real values) and fill in.
# For the GitHub Actions poller, add the same names as repo secrets instead:
#   Settings → Secrets and variables → Actions → New repository secret.

# --- required ---
# SEC asks for contact info in the User-Agent of automated EDGAR clients.
CERES_CONTACT=you@example.com

# --- admin auth (server actions: POST /api/poll, /api/purge-demo) ---
# Only the SHA-256 HASH of the token is stored anywhere. Generate a pair with:
#   node -e 'const c=require("crypto"),t=c.randomBytes(24).toString("base64url");console.log("token (save it):",t);console.log("CERES_ADMIN_TOKEN_HASH="+c.createHash("sha256").update(t).digest("hex"))'
# Send the token as:  Authorization: Bearer <token>
# Localhost is exempt unless CERES_REQUIRE_AUTH=1 — REQUIRED behind a reverse proxy,
# where every request's socket address looks local.
CERES_ADMIN_TOKEN_HASH=
#CERES_REQUIRE_AUTH=1

# --- X (Twitter) — tracked-account cashtag monitoring ---
# Needs an API bearer token from https://developer.x.com (API Basic tier or above).
# NOTE: an X Premium *subscription* is not API access — the API tier is a separate
# (paid) product. Without a bearer token this collector stays dormant.
CERES_X_BEARER=
# Comma-separated handles to track (no @). Pick your own high-signal accounts.
CERES_X_HANDLES=

# --- Reddit — direct mention counting (free) ---
# Create a "script" app at https://www.reddit.com/prefs/apps → use its id + secret.
CERES_REDDIT_CLIENT_ID=
CERES_REDDIT_CLIENT_SECRET=
# Subreddits to scan (default shown).
#CERES_SUBREDDITS=wallstreetbets,stocks,options

# --- Bluesky (free) ---
# Handle + app password (Settings → Privacy and security → App passwords).
# Use an app password, never your main account password.
CERES_BSKY_HANDLE=
CERES_BSKY_APP_PASSWORD=

# --- Telegram pump-watch (no key needed) ---
# Comma-separated PUBLIC channel names (the part after t.me/). Tickers mentioned
# in these channels are flagged as pump risks, not buy signals.
CERES_TG_CHANNELS=
